{
  "version": "1.0",
  "description": "FASE 7.2: Internal Linking Matrix for ConcertRide SEO. Defines outgoing link topology for 5 main page types.",
  "pageTypes": {
    "festival": {
      "displayName": "Festival Landing Page",
      "exampleUrl": "/festivales/:slug",
      "targetSections": [
        {
          "section": "Hero / Above Fold",
          "target": "route",
          "context": "Link to most popular routes FROM major origin cities TO this festival",
          "pattern": "Link to: /rutas/{origin-slug}-{festival-slug}",
          "examples": [
            { "from": "/festivales/mad-cool", "to": "/rutas/barcelona-mad-cool", "anchor": "Carpooling desde Barcelona" },
            { "from": "/festivales/primavera-sound", "to": "/rutas/madrid-primavera-sound", "anchor": "Cómo ir desde Madrid" }
          ],
          "linkCount": 3
        },
        {
          "section": "Origin Cities Breakdown",
          "target": "city",
          "context": "Link to each origin city landing page (/conciertos/:city)",
          "pattern": "Link to: /conciertos/{city-slug}",
          "examples": [
            { "from": "/festivales/mad-cool", "to": "/conciertos/barcelona", "anchor": "Viajes desde Barcelona" },
            { "from": "/festivales/mad-cool", "to": "/conciertos/valencia", "anchor": "Desde Valencia" }
          ],
          "linkCount": "all originCities"
        },
        {
          "section": "Related Content / FAQs",
          "target": "blog",
          "context": "Link to blog posts about this festival OR transport guides for this city",
          "pattern": "Link to: /blog/{slug}",
          "examples": [
            { "from": "/festivales/mad-cool", "to": "/blog/como-llegar-mad-cool-carpooling", "anchor": "Guía: Cómo llegar al Mad Cool" },
            { "from": "/festivales/mad-cool", "to": "/blog/transporte-festivales-madrid", "anchor": "Transporte a festivales en Madrid" }
          ],
          "linkCount": 2
        },
        {
          "section": "Related Festivals",
          "target": "festival",
          "context": "Cross-link to relatedFestivals array for discovery of other events",
          "pattern": "Link to: /festivales/{related-slug}",
          "examples": [
            { "from": "/festivales/mad-cool", "to": "/festivales/tomavistas", "anchor": "Otros festivales en verano" },
            { "from": "/festivales/primavera-sound", "to": "/festivales/sonar", "anchor": "Ver más festivales" }
          ],
          "linkCount": "count from relatedFestivals"
        }
      ]
    },
    "route": {
      "displayName": "Route Landing Page",
      "exampleUrl": "/rutas/:route",
      "targetSections": [
        {
          "section": "Hero / CTA Zone",
          "target": "festival",
          "context": "Link to the festival detail page for more event info, lineup, dates",
          "pattern": "Link to: /festivales/{festival-slug}",
          "examples": [
            { "from": "/rutas/madrid-mad-cool", "to": "/festivales/mad-cool", "anchor": "Ver festival completo" },
            { "from": "/rutas/barcelona-primavera-sound", "to": "/festivales/primavera-sound", "anchor": "Detalles del evento" }
          ],
          "linkCount": 1
        },
        {
          "section": "Origin / Destination City Info",
          "target": "city",
          "context": "Link to both origin city and destination city pages for geographic context",
          "pattern": "Link to: /conciertos/{city-slug}",
          "examples": [
            { "from": "/rutas/madrid-mad-cool", "to": "/conciertos/madrid", "anchor": "Viajes desde Madrid" },
            { "from": "/rutas/madrid-mad-cool", "to": "/conciertos/madrid", "anchor": "Festivales en Madrid" }
          ],
          "linkCount": 2
        },
        {
          "section": "Transport Guide / FAQ Section",
          "target": "blog",
          "context": "Link to blog posts about transport, how to prepare, night returns, sustainability",
          "pattern": "Link to: /blog/{slug}",
          "examples": [
            { "from": "/rutas/madrid-mad-cool", "to": "/blog/vuelta-festival-madrugada-carpooling", "anchor": "¿Cómo volver de noche?" },
            { "from": "/rutas/madrid-mad-cool", "to": "/blog/prepararse-festival-transporte", "anchor": "Guía: prepararse para el viaje" }
          ],
          "linkCount": 2
        },
        {
          "section": "Alternative Routes",
          "target": "route",
          "context": "Link to other routes departing from same origin city or arriving at same festival",
          "pattern": "Link to: /rutas/{other-origin}-{same-festival} OR /rutas/{same-origin}-{other-festival}",
          "examples": [
            { "from": "/rutas/madrid-mad-cool", "to": "/rutas/barcelona-mad-cool", "anchor": "Más rutas al Mad Cool" },
            { "from": "/rutas/madrid-mad-cool", "to": "/rutas/madrid-primavera-sound", "anchor": "Otros festivales desde Madrid" }
          ],
          "linkCount": 3
        }
      ]
    },
    "city": {
      "displayName": "City Landing Page (Concerts Hub)",
      "exampleUrl": "/conciertos/:city",
      "targetSections": [
        {
          "section": "Upcoming Festivals Section",
          "target": "festival",
          "context": "Link to all festivals in region where this city can travel",
          "pattern": "Link to: /festivales/{festival-slug}",
          "examples": [
            { "from": "/conciertos/barcelona", "to": "/festivales/mad-cool", "anchor": "Mad Cool - Madrid" },
            { "from": "/conciertos/barcelona", "to": "/festivales/primavera-sound", "anchor": "Primavera Sound - Barcelona" }
          ],
          "linkCount": "top 6 accessible festivals"
        },
        {
          "section": "Routes From This City",
          "target": "route",
          "context": "Link to all programmatic routes originating from this city",
          "pattern": "Link to: /rutas/{city-slug}-{festival-slug}",
          "examples": [
            { "from": "/conciertos/barcelona", "to": "/rutas/barcelona-mad-cool", "anchor": "Barcelona → Mad Cool" },
            { "from": "/conciertos/barcelona", "to": "/rutas/barcelona-primavera-sound", "anchor": "Barcelona → Primavera Sound" }
          ],
          "linkCount": "all routes from city"
        },
        {
          "section": "Transport Guides",
          "target": "blog",
          "context": "City-specific guides: how to travel from this city, what festivals are closest, sustainability",
          "pattern": "Link to: /blog/{slug}",
          "examples": [
            { "from": "/conciertos/barcelona", "to": "/blog/festivales-barcelona-carpooling", "anchor": "Festivales cerca de Barcelona" },
            { "from": "/conciertos/madrid", "to": "/blog/viajes-compartidos-madrid-2026", "anchor": "Carpooling desde Madrid" }
          ],
          "linkCount": 2
        },
        {
          "section": "Related Region / Venue",
          "target": "region",
          "context": "Link to region landing page for broader geographic discovery",
          "pattern": "Link to: /festivales-en/{region-slug}",
          "examples": [
            { "from": "/conciertos/madrid", "to": "/festivales-en/madrid", "anchor": "Festivales en la Comunidad de Madrid" }
          ],
          "linkCount": 1
        }
      ]
    },
    "artist": {
      "displayName": "Artist Landing Page",
      "exampleUrl": "/artistas/:slug",
      "targetSections": [
        {
          "section": "Festival Appearances",
          "target": "festival",
          "context": "Link to all festivals where this artist performs",
          "pattern": "Link to: /festivales/{festival-slug}",
          "examples": [
            { "from": "/artistas/rosalia", "to": "/festivales/mad-cool", "anchor": "Rosalía en Mad Cool" },
            { "from": "/artistas/rosalia", "to": "/festivales/primavera-sound", "anchor": "Rosalía en Primavera Sound" }
          ],
          "linkCount": "all festivals in artist.festivals[]"
        },
        {
          "section": "City / Region Where Festivals Are",
          "target": "city",
          "context": "Link to city landing pages for each festival city where artist performs",
          "pattern": "Link to: /conciertos/{city-slug}",
          "examples": [
            { "from": "/artistas/rosalia", "to": "/conciertos/madrid", "anchor": "Festivales en Madrid" },
            { "from": "/artistas/rosalia", "to": "/conciertos/barcelona", "anchor": "Festivales en Barcelona" }
          ],
          "linkCount": "unique cities from artist.festivals"
        },
        {
          "section": "Related Blog Content",
          "target": "blog",
          "context": "Link to blog posts about this artist, related artists, festival analysis",
          "pattern": "Link to: /blog/{slug}",
          "examples": [
            { "from": "/artistas/rosalia", "to": "/blog/artistas-primavera-sound-2026", "anchor": "Artistas del Primavera Sound" },
            { "from": "/artistas/rosalia", "to": "/blog/viajes-compartidos-conciertos-artistas", "anchor": "Carpooling a conciertos" }
          ],
          "linkCount": 2
        }
      ]
    },
    "blog": {
      "displayName": "Blog Post Page",
      "exampleUrl": "/blog/:slug",
      "targetSections": [
        {
          "section": "In-Content Links (Body Prose)",
          "target": "festival|route|city|artist",
          "context": "Contextual internal links woven into body paragraphs targeting relevant keywords",
          "pattern": "Multiple scattered links: 'carpooling Madrid Mad Cool' → /rutas/madrid-mad-cool, 'festivales Barcelona' → /conciertos/barcelona, etc.",
          "examples": [
            { "context": "...si quieres ir al Mad Cool sin coche...", "to": "/rutas/madrid-mad-cool", "anchor": "carpooling Madrid Mad Cool" },
            { "context": "...los festivales más cercanos a Barcelona incluyen...", "to": "/festivales/primavera-sound", "anchor": "Primavera Sound" }
          ],
          "linkCount": 4
        },
        {
          "section": "Related Blog Posts (Bottom Widget)",
          "target": "blog",
          "context": "Link to related blog posts in same category or with overlapping keywords",
          "pattern": "Link to: /blog/{related-slug}",
          "examples": [
            { "from": "/blog/autobuses-festivales-2026", "to": "/blog/carpooling-vs-autobuses-festivales", "anchor": "Leer también: Carpooling vs autobuses" }
          ],
          "linkCount": 3
        },
        {
          "section": "Call-to-Action / Footer",
          "target": "festival|route",
          "context": "Link to primary call-to-action: 'Buscar carpooling a [Festival]' or 'Ver rutas disponibles'",
          "pattern": "Link to: /festivales/{slug} or /rutas (index) or /publish",
          "examples": [
            { "from": "/blog/autobuses-festivales-2026", "to": "/publish", "anchor": "Ofrece un viaje compartido" },
            { "from": "/blog/viajes-mad-cool", "to": "/festivales/mad-cool", "anchor": "Ver carpooling al Mad Cool" }
          ],
          "linkCount": 1
        }
      ]
    }
  },
  "implementationGuidance": {
    "festival": "Use /festivales/:slug landing pages as hubs. Each festival should link OUT to top routes, all origin cities, related festivals, and topically-relevant blogs.",
    "route": "Route pages are mid-funnel. Link UP to festival detail, sideways to related routes, and DOWN to blog/city pages for supporting info.",
    "city": "City pages aggregate supply (routes) and demand (festivals). Link to all reachable festivals and all outbound routes.",
    "artist": "Artist pages are rare-query landing pages. Link to festival appearances and city hubs where they perform.",
    "blog": "Blog is the anchor for keyword richness. Weave contextual links in body prose, link to related posts, and include a primary CTA.",
    "linkJuiceFlow": "Flow: Blog (content hub) → Festival/Route (conversion) → City/Artist (discovery). Festival and Route pages are the most-linked-to.",
    "nofollow": "All internal links are dofollow. No nofollow on cross-links unless explicitly spam-detecting (e.g., user-generated content)."
  },
  "metrics": {
    "linksPerFestivalPage": "8–12 (hero route, all origin cities, 2 blogs, 2–3 related festivals)",
    "linksPerRoutePage": "8–10 (1 festival, 2 cities, 2 blogs, 3 alt routes)",
    "linksPerCityPage": "15–20 (6 festivals, all routes, 2 blogs, 1 region)",
    "linksPerBlogPost": "6–8 (4 in-body, 3 related posts, 1 CTA)"
  }
}
