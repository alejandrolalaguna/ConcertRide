---
import Layout from "@/layouts/Layout.astro";

const PASSENGER_STEPS = [
  { title: "Busca tu concierto", body: "Explora el catálogo de conciertos y festivales españoles. Usa los filtros por ciudad, género o fecha. Marca como favorito los eventos que te interesen — te avisaremos cuando haya un nuevo viaje." },
  { title: "Elige un viaje desde tu ciudad", body: "Entra a la ficha del concierto. Verás todos los viajes publicados con precio por plaza, vibe (party / chill / mixed), plazas libres y valoración del conductor." },
  { title: "Reserva tu plaza", body: "Pulsa Reservar asiento, elige cuántas plazas y método de pago. Con 'Confirmación inmediata' quedas confirmado al instante. Si no, el conductor te confirma en cuestión de horas." },
  { title: "Llega al concierto", body: "Recibes un recordatorio 24 h antes con hora de salida y datos del conductor. Pagas al conductor al subir al coche. Después, valora al conductor con 1–5 estrellas." },
];

const DRIVER_STEPS = [
  { title: "Verifica tu carnet", body: "Ve a Mi perfil → Verificar carnet de conducir. Sube una foto de tu carnet. Sin este paso no puedes publicar viajes — es el sello de confianza de la plataforma." },
  { title: "Publica tu viaje", body: "Pulsa Publicar un viaje. Selecciona el concierto, tu ciudad de origen, hora de salida, número de plazas y precio por asiento. Te sugerimos el precio óptimo según km y precio del combustible." },
  { title: "Gestiona las solicitudes", body: "Acepta o rechaza solicitudes desde la ficha del viaje. Usa el chat del viaje para coordinar el punto de recogida y compartir tu ubicación." },
  { title: "Cobra en persona", body: "El día del viaje, los pasajeros te pagan en efectivo o Bizum. ConcertRide no cobra comisión — el 100 % se queda para ti." },
];

const jsonLdPassenger = {
  "@context": "https://schema.org",
  "@type": "HowTo",
  name: "Cómo encontrar un viaje compartido a un concierto en España",
  description: "Proceso en 4 pasos para reservar plaza en un coche compartido hasta un concierto o festival usando ConcertRide.",
  totalTime: "PT5M",
  step: PASSENGER_STEPS.map((s, i) => ({ "@type": "HowToStep", position: i + 1, name: s.title, text: s.body })),
};

const jsonLdDriver = {
  "@context": "https://schema.org",
  "@type": "HowTo",
  name: "Cómo publicar un viaje a un concierto en ConcertRide (conductor)",
  description: "Proceso en 4 pasos para ofrecer plazas en tu coche a un concierto o festival. Recuperas el coste de gasolina y peajes sin comisión.",
  totalTime: "PT10M",
  step: DRIVER_STEPS.map((s, i) => ({ "@type": "HowToStep", position: i + 1, name: s.title, text: s.body })),
};
---

<Layout
  title="Cómo funciona ConcertRide"
  description="Guía paso a paso: cómo reservar plaza en un viaje compartido a un concierto o cómo publicar tu propio viaje. Gratis, sin comisiones, con conductores verificados."
  canonical="https://concertride.es/como-funciona"
  keywords="cómo funciona carpooling conciertos, cómo reservar viaje compartido concierto, cómo publicar viaje a festival, compartir coche concierto España"
>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdPassenger)} />
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdDriver)} />

  <main id="main" class="min-h-dvh bg-cr-bg text-cr-text pt-14">
    <div class="max-w-4xl mx-auto px-6 py-12 md:py-16 space-y-16">
      <header class="border-b border-cr-border pb-8 space-y-3">
        <p class="font-sans text-[11px] font-semibold uppercase tracking-[0.16em] text-cr-primary">Guía</p>
        <h1 class="font-display text-4xl md:text-6xl uppercase leading-[0.92]">Cómo funciona.</h1>
        <p class="font-sans text-base text-cr-text-muted max-w-2xl leading-relaxed">
          ConcertRide es carpooling pensado para conciertos: pasajeros y conductores que van al mismo evento
          se juntan para compartir coche, dividir gastos y llegar juntos. Gratis, sin comisiones, con conductores verificados.
        </p>
      </header>

      <!-- Pasajero -->
      <section class="space-y-8">
        <h2 class="font-display text-2xl md:text-3xl uppercase" id="pasajero">Soy pasajero — quiero ir al concierto</h2>
        <ol class="grid sm:grid-cols-2 gap-4">
          {PASSENGER_STEPS.map((step, i) => (
            <li id={`passenger-${i + 1}`} class="border border-cr-border p-5 space-y-2">
              <p class="font-mono text-[11px] text-cr-primary">{String(i + 1).padStart(2, "0")}</p>
              <h3 class="font-display text-base uppercase">{step.title}</h3>
              <p class="font-sans text-xs text-cr-text-muted leading-relaxed">{step.body}</p>
            </li>
          ))}
        </ol>
        <div>
          <a href="/concerts" class="inline-block font-sans text-xs font-semibold uppercase tracking-[0.12em] bg-cr-primary text-black border-2 border-black px-6 py-3 shadow-[4px_4px_0px_0px_rgba(0,0,0,1)] hover:shadow-[2px_2px_0px_0px_rgba(0,0,0,1)] hover:translate-x-[2px] hover:translate-y-[2px] transition-all duration-100">
            Buscar conciertos →
          </a>
        </div>
      </section>

      <!-- Conductor -->
      <section class="space-y-8 border-t border-cr-border pt-12">
        <h2 class="font-display text-2xl md:text-3xl uppercase" id="conductor">Soy conductor — quiero abrir mi coche</h2>
        <ol class="grid sm:grid-cols-2 gap-4">
          {DRIVER_STEPS.map((step, i) => (
            <li id={`driver-${i + 1}`} class="border border-cr-border p-5 space-y-2">
              <p class="font-mono text-[11px] text-cr-primary">{String(i + 1).padStart(2, "0")}</p>
              <h3 class="font-display text-base uppercase">{step.title}</h3>
              <p class="font-sans text-xs text-cr-text-muted leading-relaxed">{step.body}</p>
            </li>
          ))}
        </ol>
        <div>
          <a href="/publish" class="inline-block font-sans text-xs font-semibold uppercase tracking-[0.12em] border-2 border-cr-primary text-cr-primary px-6 py-3 hover:bg-cr-primary hover:text-black transition-colors">
            Publicar un viaje →
          </a>
        </div>
      </section>

      <!-- Garantías -->
      <section class="border-t border-cr-border pt-12 space-y-6">
        <h2 class="font-display text-2xl md:text-3xl uppercase">Garantías de seguridad</h2>
        <div class="grid sm:grid-cols-2 md:grid-cols-3 gap-4">
          {[
            { title: "Carnet verificado", body: "Foto del carnet revisada manualmente antes de publicar el primer viaje." },
            { title: "Email verificado", body: "Email verificado obligatorio para publicar o reservar." },
            { title: "Valoraciones públicas", body: "Sistema de 1–5 estrellas con reseñas visibles en cada perfil." },
            { title: "Sin comisión", body: "El 100 % del precio por asiento va al conductor. ConcertRide no cobra nada." },
            { title: "Pago en persona", body: "Efectivo o Bizum el día del viaje. Sin intermediación financiera." },
            { title: "Botón de reportar", body: "En cada perfil y viaje. Revisamos cada reporte manualmente." },
          ].map(({ title, body }) => (
            <article class="border border-cr-border p-4 space-y-2">
              <h3 class="font-display text-sm uppercase text-cr-primary">{title}</h3>
              <p class="font-sans text-xs text-cr-text-muted leading-relaxed">{body}</p>
            </article>
          ))}
        </div>
      </section>

      <div class="border-t border-cr-border pt-8 flex flex-wrap gap-4">
        <a href="/faq" class="font-sans text-xs text-cr-text-muted hover:text-cr-primary transition-colors">Preguntas frecuentes →</a>
        <a href="/concerts" class="font-sans text-xs text-cr-text-muted hover:text-cr-primary transition-colors">Explorar conciertos →</a>
        <a href="/" class="font-sans text-xs text-cr-text-muted hover:text-cr-primary transition-colors ml-auto">← Volver al inicio</a>
      </div>
    </div>
  </main>
</Layout>
