---
import Layout from "@/layouts/Layout.astro";
import { ConcertsIsland } from "@/components/ConcertsIsland";
import { CITY_LANDINGS, CITY_LANDINGS_BY_SLUG } from "@/lib/cityLandings";
import { FESTIVAL_LANDINGS } from "@/lib/festivalLandings";

export function getStaticPaths() {
  return CITY_LANDINGS.map((c) => ({ params: { city: c.slug } }));
}

const { city: citySlug } = Astro.params;
const landing = CITY_LANDINGS_BY_SLUG[citySlug as string];
if (!landing) return Astro.redirect("/concerts");

const cityFestivals = FESTIVAL_LANDINGS.filter((f) => f.citySlug === landing.slug);
const otherCities = CITY_LANDINGS.filter((c) => c.slug !== landing.slug);
const year = new Date().getFullYear();

const jsonLdCollection = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  name: `Conciertos en ${landing.display}`,
  url: `https://concertride.es/conciertos/${landing.slug}`,
  inLanguage: "es-ES",
  description: landing.blurb,
  about: {
    "@type": "Place",
    name: landing.display,
    address: {
      "@type": "PostalAddress",
      addressLocality: landing.display,
      addressRegion: landing.region,
      addressCountry: "ES",
    },
  },
  isPartOf: {
    "@type": "WebSite",
    "@id": "https://concertride.es/#website",
    name: "ConcertRide ES",
    url: "https://concertride.es",
  },
};

const jsonLdBreadcrumb = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Inicio", item: "https://concertride.es/" },
    { "@type": "ListItem", position: 2, name: "Conciertos", item: "https://concertride.es/concerts" },
    { "@type": "ListItem", position: 3, name: landing.display, item: `https://concertride.es/conciertos/${landing.slug}` },
  ],
};
---

<Layout
  title={`Conciertos en ${landing.display} ${year}`}
  description={`Todos los conciertos y festivales en ${landing.display}: ${landing.venues.slice(0, 3).join(", ")} y más. Carpooling para llegar desde cualquier ciudad de España, sin taxi ni comisiones.`}
  canonical={`https://concertride.es/conciertos/${landing.slug}`}
  keywords={`conciertos ${landing.display}, festivales ${landing.display}, carpooling ${landing.display}, coche compartido ${landing.display}, cómo ir al concierto ${landing.display}`}
>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdCollection)} />
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdBreadcrumb)} />

  <main id="main" class="min-h-dvh bg-cr-bg text-cr-text pt-14">
    <div class="max-w-6xl mx-auto px-6 pt-10 pb-6 space-y-4">
      <nav aria-label="Breadcrumb" class="font-mono text-[11px] text-cr-text-muted flex items-center gap-2">
        <a href="/" class="hover:text-cr-primary">Inicio</a>
        <span aria-hidden="true">/</span>
        <a href="/concerts" class="hover:text-cr-primary">Conciertos</a>
        <span aria-hidden="true">/</span>
        <span class="text-cr-text-muted">{landing.display}</span>
      </nav>

      <p class="font-sans text-[11px] font-semibold uppercase tracking-[0.16em] text-cr-primary inline-flex items-center gap-2">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
        {landing.region}
      </p>

      <h1 class="font-display text-4xl md:text-6xl uppercase leading-[0.92]">
        Conciertos en {landing.display}.
      </h1>

      <p class="font-sans text-sm md:text-base text-cr-text-muted max-w-2xl leading-relaxed">
        {landing.blurb}
      </p>

      {landing.venues.length > 0 && (
        <div class="flex flex-wrap gap-2 pt-2">
          {landing.venues.map((v) => (
            <span class="inline-flex items-center gap-1.5 font-mono text-[11px] text-cr-text-muted border border-cr-border px-2 py-1">
              <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18V5l12-2v13"/><circle cx="6" cy="18" r="3"/><circle cx="18" cy="16" r="3"/></svg>
              {v}
            </span>
          ))}
        </div>
      )}
    </div>

    <!-- Próximos conciertos (dynamic) -->
    <section class="max-w-6xl mx-auto px-6 pb-16">
      <h2 class="font-display text-xl md:text-2xl uppercase mb-6">Próximos conciertos</h2>
      <ConcertsIsland
        client:load
        city={landing.city}
        loadingLabel={`Cargando conciertos en ${landing.display}…`}
        emptyLabel="Sin conciertos programados ahora mismo"
      />
    </section>

    <!-- Cómo ir -->
    <section class="max-w-6xl mx-auto px-6 pb-24 border-t border-cr-border pt-12 space-y-6">
      <h2 class="font-display text-xl md:text-2xl uppercase">
        Cómo ir a un concierto en {landing.display}
      </h2>
      <div class="grid md:grid-cols-3 gap-4 font-sans text-sm text-cr-text-muted leading-relaxed">
        <article class="space-y-2">
          <h3 class="font-display text-base uppercase text-cr-primary">1. Busca el concierto</h3>
          <p>Encuentra el evento al que vas en esta página. Cada ficha muestra cuántos viajes compartidos están ya publicados desde distintas ciudades de España.</p>
        </article>
        <article class="space-y-2">
          <h3 class="font-display text-base uppercase text-cr-primary">2. Elige un viaje</h3>
          <p>Revisa precio por plaza, vibe (party/chill/mixed) y la valoración del conductor. Puedes ver qué otros pasajeros ya están confirmados.</p>
        </article>
        <article class="space-y-2">
          <h3 class="font-display text-base uppercase text-cr-primary">3. Llega juntos</h3>
          <p>Pagas al conductor en efectivo o Bizum el día del viaje. Recibes un recordatorio 24h antes con la hora y el punto de encuentro.</p>
        </article>
      </div>

      <div class="pt-6 flex flex-wrap gap-4 border-t border-cr-border">
        <a href="/concerts" class="inline-flex items-center gap-2 font-sans text-xs font-semibold uppercase tracking-[0.12em] text-cr-text-muted hover:text-cr-primary transition-colors">
          Ver todas las ciudades →
        </a>
        <a href="/como-funciona" class="inline-flex items-center gap-2 font-sans text-xs font-semibold uppercase tracking-[0.12em] text-cr-text-muted hover:text-cr-primary transition-colors">
          Cómo funciona →
        </a>
        <a href="/faq" class="inline-flex items-center gap-2 font-sans text-xs font-semibold uppercase tracking-[0.12em] text-cr-text-muted hover:text-cr-primary transition-colors ml-auto">
          FAQ →
        </a>
      </div>
    </section>

    <!-- Festivales en esta ciudad -->
    {cityFestivals.length > 0 && (
      <section class="max-w-6xl mx-auto px-6 pb-12 border-t border-cr-border pt-10">
        <h2 class="font-display text-lg uppercase text-cr-text-muted mb-4">
          Festivales en {landing.display}
        </h2>
        <ul class="flex flex-wrap gap-2">
          {cityFestivals.map((f) => (
            <li>
              <a
                href={`/festivales/${f.slug}`}
                class="inline-flex items-center gap-1.5 font-sans text-xs text-cr-text-muted hover:text-cr-primary border border-cr-border hover:border-cr-primary px-3 py-1.5 transition-colors"
              >
                Cómo ir a {f.shortName} →
              </a>
            </li>
          ))}
        </ul>
      </section>
    )}

    <!-- Otras ciudades -->
    <section class="max-w-6xl mx-auto px-6 pb-24 border-t border-cr-border pt-10">
      <h2 class="font-display text-lg uppercase text-cr-text-muted mb-4">Otras ciudades</h2>
      <ul class="flex flex-wrap gap-2">
        {otherCities.map((c) => (
          <li>
            <a
              href={`/conciertos/${c.slug}`}
              class="inline-flex items-center gap-1.5 font-sans text-xs text-cr-text-muted hover:text-cr-primary border border-cr-border hover:border-cr-primary px-3 py-1.5 transition-colors"
            >
              {c.display}
            </a>
          </li>
        ))}
      </ul>
    </section>
  </main>
</Layout>
