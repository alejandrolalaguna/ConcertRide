---
const year = new Date().getFullYear();
---

<footer class="border-t border-cr-border bg-cr-bg text-cr-text">
  <div class="max-w-6xl mx-auto px-6 py-12 grid grid-cols-1 sm:grid-cols-2 md:grid-cols-4 gap-10">
    <div class="space-y-4">
      <p class="font-display text-lg uppercase tracking-[0.06em]">
        Concert<span class="text-cr-primary">Ride</span>
      </p>
      <p class="font-mono text-xs text-cr-text-muted leading-relaxed max-w-xs">
        La plataforma de viajes compartidos a conciertos en España. Sin intermediarios, sin comisiones.
      </p>
      <p class="font-mono text-xs text-cr-text-muted">
        ¿Dudas?{" "}
        <a href="mailto:alejandrolalaguna@gmail.com" class="text-cr-primary hover:text-cr-primary/80 underline underline-offset-2">
          alejandrolalaguna@gmail.com
        </a>
      </p>
    </div>

    <div>
      <p class="font-sans text-[10px] font-semibold uppercase tracking-[0.16em] text-cr-text-muted mb-4">Plataforma</p>
      <nav class="flex flex-col gap-2">
        <a href="/concerts" class="font-sans text-xs text-cr-text-muted hover:text-cr-primary transition-colors">Explorar conciertos</a>
        <a href="/publish" class="font-sans text-xs text-cr-text-muted hover:text-cr-primary transition-colors">Publicar un viaje</a>
        <a href="/register" class="font-sans text-xs text-cr-text-muted hover:text-cr-primary transition-colors">Crear cuenta</a>
        <a href="/como-funciona" class="font-sans text-xs text-cr-text-muted hover:text-cr-primary transition-colors">Cómo funciona</a>
        <a href="/guia-transporte-festivales" class="font-sans text-xs text-cr-text-muted hover:text-cr-primary transition-colors">Guía de transporte</a>
        <a href="/faq" class="font-sans text-xs text-cr-text-muted hover:text-cr-primary transition-colors">Preguntas frecuentes</a>
        <a href="/acerca-de" class="font-sans text-xs text-cr-text-muted hover:text-cr-primary transition-colors">Acerca de</a>
        <a href="/contacto" class="font-sans text-xs text-cr-text-muted hover:text-cr-primary transition-colors">Contacto</a>
      </nav>
    </div>

    <div>
      <p class="font-sans text-[10px] font-semibold uppercase tracking-[0.16em] text-cr-text-muted mb-4">Festivales</p>
      <nav class="flex flex-col gap-2">
        <a href="/festivales/mad-cool" class="font-sans text-xs text-cr-text-muted hover:text-cr-primary transition-colors">Mad Cool</a>
        <a href="/festivales/primavera-sound" class="font-sans text-xs text-cr-text-muted hover:text-cr-primary transition-colors">Primavera Sound</a>
        <a href="/festivales/sonar" class="font-sans text-xs text-cr-text-muted hover:text-cr-primary transition-colors">Sónar</a>
        <a href="/festivales/fib" class="font-sans text-xs text-cr-text-muted hover:text-cr-primary transition-colors">FIB Benicàssim</a>
        <a href="/festivales/bbk-live" class="font-sans text-xs text-cr-text-muted hover:text-cr-primary transition-colors">BBK Live</a>
        <a href="/festivales/resurrection-fest" class="font-sans text-xs text-cr-text-muted hover:text-cr-primary transition-colors">Resurrection Fest</a>
        <a href="/festivales/vina-rock" class="font-sans text-xs text-cr-text-muted hover:text-cr-primary transition-colors">Viña Rock</a>
        <a href="/festivales/arenal-sound" class="font-sans text-xs text-cr-text-muted hover:text-cr-primary transition-colors">Arenal Sound</a>
      </nav>
    </div>

    <div>
      <p class="font-sans text-[10px] font-semibold uppercase tracking-[0.16em] text-cr-text-muted mb-4">Legal</p>
      <nav class="flex flex-col gap-2">
        <a href="/aviso-legal" class="font-sans text-xs text-cr-text-muted hover:text-cr-primary transition-colors">Aviso legal</a>
        <a href="/privacidad" class="font-sans text-xs text-cr-text-muted hover:text-cr-primary transition-colors">Política de privacidad</a>
        <a href="/cookies" class="font-sans text-xs text-cr-text-muted hover:text-cr-primary transition-colors">Política de cookies</a>
        <a href="/terminos" class="font-sans text-xs text-cr-text-muted hover:text-cr-primary transition-colors">Términos y condiciones</a>
      </nav>
    </div>
  </div>

  <div class="border-t border-cr-border">
    <div class="max-w-6xl mx-auto px-6 py-4 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-2">
      <p class="font-mono text-[10px] text-cr-text-muted">© {year} ConcertRide ES. Todos los derechos reservados.</p>
      <p class="font-mono text-[10px] text-cr-text-muted flex flex-wrap gap-x-2 gap-y-1">
        <span>Datos:</span>
        <a href="https://developer.ticketmaster.com" target="_blank" rel="noopener noreferrer" class="hover:text-cr-primary transition-colors">Ticketmaster</a>
        <span>·</span>
        <span>Mapas:</span>
        <a href="https://www.openstreetmap.org/copyright" target="_blank" rel="noopener noreferrer" class="hover:text-cr-primary transition-colors">OpenStreetMap contributors</a>
        <span>·</span>
        <a href="https://carto.com/attributions" target="_blank" rel="noopener noreferrer" class="hover:text-cr-primary transition-colors">CARTO</a>
      </p>
    </div>
  </div>
</footer>
