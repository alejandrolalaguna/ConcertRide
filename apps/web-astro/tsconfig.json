{
  "extends": "astro/tsconfigs/strict",
  "include": [".astro/types.d.ts", "**/*"],
  "exclude": ["dist"],
  "compilerOptions": {
    "baseUrl": ".",
    "ignoreDeprecations": "5.0",
    "paths": {
      "@/*": ["src/*"],
      "@concertride/types": ["../../packages/types/src/index.ts"]
    },
    "jsx": "react-jsx",
    "jsxImportSource": "react"
  }
}
