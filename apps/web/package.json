{
  "name": "@concertride/web",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build && npm run build:ssr && npm run prerender && npm run inline:critical-css && npm run gen:llms-routes && npm run validate:schema && npm run audit:meta",
    "build:report": "cross-env ANALYZE=true vite build",
    "build:ssr": "node scripts/build-ssr.mjs",
    "prerender": "node scripts/prerender.mjs",
    "inline:critical-css": "node scripts/inline-critical-css.mjs",
    "validate:schema": "node scripts/validate-schema.mjs",
    "audit:meta": "node scripts/audit-meta.mjs",
    "lint:brand": "node scripts/lint-brand-restrictions.mjs",
    "preview": "vite preview",
    "type-check": "tsc --noEmit",
    "favicons": "node scripts/gen-favicons.mjs",
    "gen:og": "node scripts/gen-og-festivals.mjs",
    "gen:llms-routes": "node scripts/gen-llms-routes.mjs",
    "audit:cwv-static": "node scripts/audit-cwv-static.mjs",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@concertride/types": "*",
    "@sentry/react": "^8.55.1",
    "canvas-confetti": "^1.9.4",
    "leaflet": "^1.9.4",
    "lucide-react": "^1.8.0",
    "motion": "^11.13.1",
    "posthog-js": "^1.371.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-leaflet": "^4.2.1",
    "react-router-dom": "^6.28.0"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.0.0",
    "@tailwindcss/vite": "^4.0.0-beta.7",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/canvas-confetti": "^1.9.0",
    "@types/leaflet": "^1.9.21",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^4.1.4",
    "beasties": "^0.4.2",
    "cross-env": "^7.0.3",
    "jsdom": "^25.0.1",
    "rollup-plugin-visualizer": "^5.12.0",
    "sharp": "^0.33.5",
    "tailwindcss": "^4.0.0-beta.7",
    "typescript": "^5.6.3",
    "vite": "^6.0.3",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.1.4"
  }
}
