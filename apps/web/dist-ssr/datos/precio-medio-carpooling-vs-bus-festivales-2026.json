        "description": "Tiempo estimado de conducción origen → recinto"
      },
      {
        "field": "co2_ahorrado_kg",
        "type": "number",
        "unit": "kg",
        "description": "CO2 ahorrado por asiento al pasar de coche individual (130 g/km) a carpooling con 3.5 ocupantes (44 g/km)"
      }
    ]
  },
