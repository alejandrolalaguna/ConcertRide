# ConcertRide ES — environment variables
# Copy to .dev.vars (Workers local) or configure via `wrangler secret put` for prod.
# The frontend reads VITE_* vars from .env.local in apps/web/.

# --- Turso (libSQL) ---
TURSO_DATABASE_URL=libsql://your-db.turso.io
TURSO_AUTH_TOKEN=

# --- Ticketmaster Discovery API ---
# https://developer.ticketmaster.com/
TICKETMASTER_API_KEY=

# --- Resend (magic-link email delivery) ---
# https://resend.com/api-keys
RESEND_API_KEY=

# --- Auth (JWT signing) ---
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=

# --- Ingestion endpoint guard ---
# Random string; required in the `x-ingest-secret` header to hit /api/ingest/run
INGEST_SECRET=

# --- Frontend ---
# Used by apps/web. In production the API is served from the same Worker so leave blank.
VITE_API_BASE_URL=http://127.0.0.1:8787

# --- PostHog (product analytics) ---
# Get from posthog.com → Project settings → Project API Key
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://us.i.posthog.com

# --- Microsoft Clarity (heatmaps + session recording, free) ---
# Get from https://clarity.microsoft.com → Settings → Setup → Project ID
# Loaded only after the user accepts the analytics cookie banner.
# VITE_CLARITY_PROJECT_ID=

# --- Test mode (Playwright E2E only) ---
# When "true" AND ENVIRONMENT=development, the Worker mounts /api/__test__/*
# helpers used by Playwright (seed users, read mailbox, flip license flags).
# MUST be empty in any production deployment. Guarded server-side regardless.
# TEST_MODE=true
