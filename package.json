{
  "name": "concertride-es",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently --kill-others --names api,web --prefix-colors yellow,cyan \"npm run dev:api\" \"npm run dev:web\"",
    "dev:web": "npm run dev --workspace=@concertride/web",
    "dev:api": "npm run dev --workspace=@concertride/api",
    "build": "npm run build --workspace=@concertride/web && npm run build --workspace=@concertride/api",
    "build:web": "npm run build --workspace=@concertride/web",
    "build:api": "npm run build --workspace=@concertride/api",
    "type-check": "npm run type-check --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "e2e": "playwright test",
    "deploy": "npm run build:web && wrangler deploy"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.2",
    "@playwright/test": "^1.59.1",
    "concurrently": "^9.2.1",
    "typescript": "^5.6.3",
    "wrangler": "^3.90.0"
  },
  "engines": {
    "node": ">=20"
  }
}
